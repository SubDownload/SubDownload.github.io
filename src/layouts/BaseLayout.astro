---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pageType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string;
}

const {
  title = 'SubDownload — Summarize YouTube videos into your AI knowledge base',
  description = "SubDownload turns any YouTube link into a transcript, summary, and searchable note in your AI knowledge base. Works with Claude, ChatGPT, and Cursor.",
  image = '/og-default.png',
  pageType = 'website',
  publishedTime,
  modifiedTime,
  keywords,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/logo.svg" />
    <link rel="alternate" type="application/rss+xml" title="SubDownload Blog" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap.xml" />

    <meta property="og:site_name" content="SubDownload" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    {pageType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {pageType === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <slot name="head" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
