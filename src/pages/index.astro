---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="SubDownload — YouTube subtitles, transcripts, effortless."
  description="Pull clean transcripts from any YouTube video. Search channels and playlists. Built for creators, researchers, and teams."
>
  <section class="hero">
    <h1>
      Subtitles.<br />
      Transcripts.<br />
      <span class="gradient">Effortless.</span>
    </h1>
    <p class="lead">
      Pull clean transcripts from any YouTube video. Search channels and
      playlists. Built for creators, researchers, and teams that actually read
      what they watch.
    </p>
    <div class="cta">
      <a href="https://subdownload.com" class="btn">Open SubDownload</a>
      <a href="/blog/" class="btn-ghost">Read the blog &rsaquo;</a>
    </div>
  </section>

  <section class="section alt">
    <h2>One tool. Every video.</h2>
    <p class="lead">
      Paste a link. Get the transcript. Translate it, search it, quote it. It's
      that fast.
    </p>
    <div class="features">
      <div class="feature">
        <div class="icon">T</div>
        <h3>Instant transcripts</h3>
        <p>Clean, timestamped captions for any YouTube video &mdash; shorts, livestreams, and long-form.</p>
      </div>
      <div class="feature">
        <div class="icon">C</div>
        <h3>Channels &amp; playlists</h3>
        <p>Browse every video on a channel or inside a playlist, then grab transcripts in bulk.</p>
      </div>
      <div class="feature">
        <div class="icon">S</div>
        <h3>Search inside videos</h3>
        <p>Full-text search across a channel so you can find the exact moment &mdash; not just the right video.</p>
      </div>
    </div>
  </section>

  <section class="section dark">
    <h2>Built for anyone who watches with intent.</h2>
    <p class="lead">
      Researchers. Podcasters. Learners. Product teams. Anyone who thinks
      better in text.
    </p>
    <div class="features">
      <div class="feature">
        <h3>Fast by design</h3>
        <p>Transcripts show up in seconds. No uploads. No queues. No signup for the basics.</p>
      </div>
      <div class="feature">
        <h3>Any language</h3>
        <p>Auto-detect the source language and translate to whatever you read in.</p>
      </div>
      <div class="feature">
        <h3>Plays with your stack</h3>
        <p>An MCP server so Claude, Cursor, and your agents can fetch transcripts on demand.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Start with a URL.<br />End with a transcript.</h2>
    <p class="lead">No account needed to try it.</p>
    <div class="cta">
      <a href="https://subdownload.com" class="btn">Try SubDownload</a>
    </div>
  </section>
</BaseLayout>
