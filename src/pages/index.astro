---
import BaseLayout from '../layouts/BaseLayout.astro';

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SubDownload',
  url: 'https://subdownload.com',
  logo: 'https://pages.subdownload.com/logo.svg',
  sameAs: ['https://pages.subdownload.com'],
};

const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'SubDownload',
  url: 'https://subdownload.com',
  description:
    'Summarize YouTube videos into your AI knowledge base. Transcripts, instant summaries, and a searchable library — works with Claude, ChatGPT, and Cursor.',
};

const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'SubDownload',
  applicationCategory: 'ProductivityApplication',
  operatingSystem: 'Web, REST API, MCP',
  url: 'https://subdownload.com',
  description:
    'AI YouTube knowledge base. Paste any link to get a transcript, AI summary, and searchable note. Plugs into Claude, ChatGPT, Cursor, and 40+ AI agents via MCP server, REST API, and Agent Skills.',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---
<BaseLayout
  title="SubDownload — Summarize YouTube Videos Into Your AI Knowledge Base"
  description="Paste any YouTube link. SubDownload returns a transcript, AI summary, and searchable note in your personal knowledge base — works with Claude, ChatGPT, and Cursor, even for videos without captions."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productJsonLd)} />

  <section class="hero">
    <h1>
      Summarize YouTube videos<br />
      into your <span class="gradient">AI knowledge base.</span>
    </h1>
    <p class="lead">
      SubDownload turns any YouTube link into a clean transcript, an instant
      AI summary, and a searchable note in your personal Knowledge Base.
      Works with Claude, ChatGPT, and Cursor — even for videos without
      captions.
    </p>
    <div class="cta">
      <a href="https://subdownload.com?utm_source=pages_home&utm_medium=hero&utm_campaign=LAUNCH" class="btn">Open SubDownload</a>
      <a href="/blog/introducing-subdownload/" class="btn-ghost">Read the launch note &rsaquo;</a>
    </div>
  </section>

  <section class="section alt">
    <h2>Three things SubDownload does for you.</h2>
    <p class="lead">
      Paste a link. Get a transcript, a summary, and a saved note your AI
      can reach. Three pillars, in the order they actually matter.
    </p>
    <div class="features">
      <div class="feature">
        <div class="icon">A</div>
        <h3>Works across your AI stack</h3>
        <p>Claude, ChatGPT, Cursor, and 40+ MCP-compatible agents. Transcripts and summaries are one tool call away — REST API, MCP server, or Agent Skills, your pick.</p>
      </div>
      <div class="feature">
        <div class="icon">L</div>
        <h3>Your personal video library</h3>
        <p>Every video you process files into a Knowledge Base you own. Tag, favorite, and search across the full text of everything you've watched.</p>
      </div>
      <div class="feature">
        <div class="icon">S</div>
        <h3>Summaries in seconds</h3>
        <p>Instant AI summary of any video. Transcript renders side-by-side with the player. Six export formats. Works even on videos without official captions.</p>
      </div>
    </div>
  </section>

  <section class="section dark">
    <h2>Built for anyone who reads what they watch.</h2>
    <p class="lead">
      Researchers. Indie devs. PKM folks. Content creators. Anyone who
      thinks better in text than in playback.
    </p>
    <div class="features">
      <div class="feature">
        <h3>For researchers</h3>
        <p>Skim hours of conference talks in minutes. Quote transcripts directly into your notes — verifiable, timestamped, traceable.</p>
      </div>
      <div class="feature">
        <h3>For indie devs &amp; agent tinkerers</h3>
        <p>Plug an MCP server into Claude Desktop, Cursor, or Claude Code in a few minutes. <a href="/blog/claude-youtube-mcp/">Setup walkthrough &rsaquo;</a></p>
      </div>
      <div class="feature">
        <h3>For PKM &amp; knowledge builders</h3>
        <p>Build a searchable library that compounds with every video. <a href="/blog/youtube-knowledge-base/">How to build one &rsaquo;</a></p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Paste a link.<br />Keep what's worth keeping.</h2>
    <p class="lead">No account needed for the basic tool.</p>
    <div class="cta">
      <a href="https://subdownload.com?utm_source=pages_home&utm_medium=cta&utm_campaign=LAUNCH" class="btn">Open SubDownload</a>
      <a href="/blog/" class="btn-ghost">Read the blog &rsaquo;</a>
    </div>
  </section>
</BaseLayout>
